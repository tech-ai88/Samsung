    "import joblib\n",
    "import numpy as np\n",
    "\n",
    "# 모델 로드\n",
    "pipeline=joblib.load(\"knn_pipeline.pkl\")\n",
    "\n",
    "# 새로운 데이터 예측 (iris 기준 4개 feature)\n",
    "sample=np.array([[5.1, 3.5, 1.4, 0.2]])\n",
    "prediction=pipeline.predict(sample)\n",
    "\n",
    "print(\"예측 결과:\", prediction)"
